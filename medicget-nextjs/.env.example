# Template de variables de entorno para docker-compose.yml.
# Copialo a `.env` (no versionado) y completá con valores reales.
#
#   cp .env.example .env

# ─── PayPhone ──────────────────────────────────────────────────────────────
# Token Bearer obtenido del panel de comercio en https://www.payphone.com
PAYPHONE_TOKEN=
# Store / Tienda ID — UUID que asigna PayPhone al crear la tienda.
PAYPHONE_STORE_ID=
# Sandbox o producción.
PAYPHONE_BASE_URL=https://pay.payphonetodoesposible.com/api

# ─── Plataforma ────────────────────────────────────────────────────────────
# Comisión que toma la plataforma por cada cita pagada (porcentaje).
PLATFORM_FEE_PCT=10
# Servidor Jitsi para videollamadas. Vacío = público gratis.
JITSI_BASE_URL=https://meet.jit.si

# ─── Frontend ──────────────────────────────────────────────────────────────
# URL pública del frontend — se embebe en los links de emails (verify-email,
# reset-password, etc).
FRONTEND_URL=http://localhost:5173
