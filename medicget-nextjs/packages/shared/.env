# =============================================================================
# Local-host DATABASE_URL for Prisma CLI commands.
#
# IMPORTANT — ports:
#   • Inside Docker: services reach Postgres at `postgres:5432` (the docker
#     network DNS) — that URL is injected by docker-compose.yml and takes
#     precedence over this file when running inside a container.
#   • From the Windows host (this file): Postgres is published on 5433 to
#     avoid colliding with a native PostgreSQL 17 install that already
#     occupies 5432. See `docker-compose.yml` → postgres.ports.
#
# Password matches `POSTGRES_PASSWORD` in docker-compose.yml.
# =============================================================================
DATABASE_URL=postgresql://postgres:1998jh@localhost:5433/medicget_dev?schema=public
