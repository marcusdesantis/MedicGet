generator client {
  provider      = "prisma-client-js"
  // `native`                       → host OS for local dev (Windows / macOS / Linux)
  // `linux-musl-openssl-3.0.x`    → required by node:20-alpine (Alpine 3.19+ ships OpenSSL 3)
  // Without this, Prisma generates the OpenSSL 1.1 engine and fails at runtime with:
  //   "Error loading shared library libssl.so.1.1: No such file or directory"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CLINIC
  DOCTOR
  PATIENT
  ADMIN
}

enum PlanAudience {
  DOCTOR
  CLINIC
}

enum PlanCode {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
  /// Registró pero todavía no verificó su email. No puede loguearse.
  PENDING_VERIFICATION
}

enum AppointmentStatus {
  PENDING
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentModality {
  ONLINE      // videollamada
  PRESENCIAL  // consulta en consultorio físico
  CHAT        // mensajería en vivo
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  PENDING
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_REMINDER
  /// El médico marcó la cita como atendida, el paciente debe confirmar.
  APPOINTMENT_COMPLETED_BY_DOCTOR
  /// Doble validación cerrada: ambas partes confirmaron la atención.
  APPOINTMENT_FINALIZED
  PAYMENT_RECEIVED
  REVIEW_RECEIVED
  /// Verificación de email pendiente / completada.
  EMAIL_VERIFICATION
  SYSTEM
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Core User / Identity ─────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  role            Role
  status          UserStatus @default(ACTIVE)
  /// Set cuando el usuario hace click en el enlace o ingresa el código
  /// de verificación. Mientras sea null y status sea PENDING_VERIFICATION,
  /// el login está bloqueado. Mantenemos también el timestamp aún cuando
  /// el status ya cambió a ACTIVE para auditoría.
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdBy       String?
  updatedBy       String?

  profile       Profile?
  clinic        Clinic?
  doctor        Doctor?
  patient       Patient?
  notifications Notification[]
  subscriptions Subscription[]
  pushSubscriptions PushSubscription[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([role])
  @@index([status])
  @@index([email])
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  address   String?
  city      String?
  province  String?
  country   String?
  /// Coordenadas geográficas. Opcionales: el médico independiente
  /// puede atender sólo virtual y dejarlas en null. Cuando se
  /// completan, se usan para "médicos cerca de vos" y para el marker
  /// en el mapa del perfil público.
  latitude  Float?
  longitude Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country, province])
}

// ─── Clinic ───────────────────────────────────────────────────────────────────

model Clinic {
  id          String     @id @default(cuid())
  userId      String     @unique
  name        String
  address     String?
  city        String?
  province    String?
  country     String?
  /// Coordenadas geográficas — obligatorias en producción para clínicas
  /// pero el schema las deja opcionales para no bloquear la creación
  /// inicial. El frontend valida que estén presentes antes de marcar el
  /// perfil como "completo".
  latitude    Float?
  longitude   Float?
  description String?
  phone       String?
  email       String?
  website     String?
  logoUrl     String?
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctors      Doctor[]
  appointments Appointment[]

  @@index([status])
  @@index([country, province])
}

// ─── Doctor ───────────────────────────────────────────────────────────────────

model Doctor {
  id              String     @id @default(cuid())
  userId          String     @unique
  // clinicId is optional so doctors can self-register and complete their
  // professional profile (specialty, license, prices) without immediately
  // associating with a clinic. They can later link to a clinic from
  // /doctor/setup or via a clinic invitation flow.
  clinicId        String?
  specialty       String
  licenseNumber   String?
  experience      Int        @default(0)
  pricePerConsult Float      @default(0)
  bio             String?
  consultDuration Int        @default(30)
  languages       String[]
  // Modalities the doctor accepts. Drives which options the patient sees on
  // the booking page — defaults to [ONLINE] so a fresh doctor can already
  // receive video consults. They opt in to PRESENCIAL / CHAT from their
  // profile page when they're ready.
  modalities      AppointmentModality[] @default([ONLINE])
  rating          Float      @default(0)
  reviewCount     Int        @default(0)
  available       Boolean    @default(true)
  status          UserStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic         Clinic?              @relation(fields: [clinicId], references: [id])
  appointments   Appointment[]
  availability   DoctorAvailability[]
  slots          AppointmentSlot[]
  reviews        Review[]
  medicalRecords MedicalRecord[]

  @@index([clinicId])
  @@index([specialty])
  @@index([available])
  @@index([status])
}

// ─── Doctor Availability / Schedule ──────────────────────────────────────────

model DoctorAvailability {
  id        String    @id @default(cuid())
  doctorId  String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
}

// ─── Appointment Slots ────────────────────────────────────────────────────────

model AppointmentSlot {
  id            String   @id @default(cuid())
  doctorId      String
  date          DateTime @db.Date
  time          String
  isBooked      Boolean  @default(false)
  appointmentId String?  @unique
  createdAt     DateTime @default(now())

  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@unique([doctorId, date, time])
  @@index([doctorId])
  @@index([date])
  @@index([isBooked])
}

// ─── Patient ──────────────────────────────────────────────────────────────────

model Patient {
  id          String     @id @default(cuid())
  userId      String     @unique
  dateOfBirth DateTime?
  bloodType   String?
  // Free-form clinical lists. Modeled as String[] to keep MVP simple — once
  // we need structured prescriptions/diagnoses with dosage, ICD codes, etc.
  // we'll graduate to dedicated `Prescription` and `Diagnosis` models.
  allergies   String[]
  conditions  String[]
  medications String[]
  notes       String?
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  reviews        Review[]
  medicalRecords MedicalRecord[]

  @@index([status])
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id           String              @id @default(cuid())
  patientId    String
  doctorId     String
  // `clinicId` is OPTIONAL so independent doctors (without clinic
  // association) can also receive bookings. When the doctor IS associated
  // with a clinic, we still record it for billing/reporting.
  clinicId     String?
  date         DateTime            @db.Date
  time         String
  status       AppointmentStatus   @default(PENDING)
  // Modality drives the post-payment flow:
  //   • ONLINE     → generate videollamada link
  //   • PRESENCIAL → no link, in-person consult at doctor's address
  //   • CHAT       → enable in-app chat for that appointment
  modality     AppointmentModality @default(ONLINE)
  price        Float
  notes        String?
  cancelReason String?
  // Generated automatically when modality === ONLINE — a Jitsi Meet room
  // URL the patient and doctor use to join the consult. Sent by email at
  // booking time and rotated only if the appointment is rescheduled.
  meetingUrl   String?
  // ─── PRESENCIAL check-in workflow ───────────────────────────────────
  // Both timestamps are optional and only meaningful for PRESENCIAL
  // appointments. They drive the "I'm on my way / I've arrived" /
  // "Patient checked-in" UX so the doctor knows when the patient is in
  // the waiting room and the patient sees real-time confirmation.
  patientArrivedAt  DateTime?
  doctorCheckedInAt DateTime?
  // ─── Doble validación de finalización ───────────────────────────────
  // Flujo: médico marca "atendida" → `doctorCompletedAt` se setea + se
  // crea notificación al paciente. Paciente confirma desde su lado →
  // `patientConfirmedAt` se setea y la cita transiciona a COMPLETED.
  // Si pasan >24h del doctorCompletedAt sin que el paciente confirme,
  // el sweeper de citas vencidas la cierra como COMPLETED de oficio.
  doctorCompletedAt  DateTime?
  patientConfirmedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBy    String?
  updatedBy    String?

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  clinic  Clinic? @relation(fields: [clinicId], references: [id])

  slot    AppointmentSlot?
  review  Review?
  payment Payment?
  messages ChatMessage[]
  medicalRecord MedicalRecord?

  @@index([patientId])
  @@index([doctorId])
  @@index([clinicId])
  @@index([date])
  @@index([status])
}

// ─── Reviews / Ratings ────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  patientId     String
  doctorId      String
  rating        Int
  comment       String?
  isPublic      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@index([patientId])
  @@index([rating])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  amount        Float
  // ─── Platform fee split ────────────────────────────────────────────
  // `platformFee`  → what MedicGet retains. Calculated on confirm using
  //                   PLATFORM_FEE_PCT env var (default 10%).
  // `doctorAmount` → what gets credited to the doctor/clinic.
  //                   Always equals `amount - platformFee`.
  platformFee   Float         @default(0)
  doctorAmount  Float         @default(0)
  method        PaymentMethod @default(PENDING)
  status        PaymentStatus @default(PENDING)
  // PayPhone integration fields
  // `payphonePaymentId`   → numeric id returned by PayPhone /Sale (used to
  //                         confirm and to issue refunds)
  // `paymentToken`        → opaque token from PayPhone /Sale, included in
  //                         the redirect URL the patient opens
  // `paymentUrl`          → the URL we redirect the patient to. Cached so
  //                         they can reopen the same checkout if they
  //                         close the tab before paying.
  // `expiresAt`           → after this timestamp, the unpaid appointment
  //                         is auto-cancelled and the slot freed.
  payphonePaymentId String?
  paymentToken      String?
  paymentUrl        String?
  expiresAt         DateTime?
  // Generic transaction id (for non-PayPhone methods) and audit fields.
  transactionId String?
  paidAt        DateTime?
  refundedAt    DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([status])
  @@index([method])
  @@index([expiresAt])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

// ─── Push Notifications (Web Push API) ───────────────────────────────────────
//
// Una suscripción por dispositivo+navegador. Un mismo usuario puede tener
// varias (ej: chrome desktop + safari móvil). Eliminamos las que el
// servidor de push reporta como inválidas (HTTP 410).

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  /// JSON con `p256dh` y `auth` (claves de cifrado del navegador).
  keys      Json
  /// User-agent del navegador al suscribirse — útil para mostrar
  /// "Chrome en Windows" en una futura UI de "dispositivos conectados".
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Password Reset Tokens ────────────────────────────────────────────────────
//
// Generados por POST /auth/forgot-password. Guardamos el HASH del token
// (sha256) y mandamos el token plano por email — esto evita que un dump
// de la DB exponga tokens válidos. Vencen a los 60 minutos. `usedAt` es
// no-nulo cuando ya se canjearon — los tokens son single-use.

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  /// SHA-256 hex del token plano que se envió por email.
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  /// IP de quien pidió el reset — útil para auditoría.
  requestIp String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Token para verificación de email tras registro. Análogo al
/// PasswordResetToken pero con doble formato:
///   • `tokenHash`: SHA-256 del token largo embebido en el link.
///   • `code`:      6 dígitos numéricos para que el usuario pueda copiar
///                  el código del email a la app (útil en mobile).
/// Cualquiera de los dos sirve para verificar. Single-use, expira a las
/// 24h.
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
}

/// Formulario de atención médica — uno por cita, llenado por el médico
/// durante / después de la consulta. Captura motivo, síntomas y
/// enfermedades preexistentes del paciente para esa consulta puntual.
/// Diferente del array `Patient.conditions` (que es el "perfil de
/// fondo" del paciente) — `MedicalRecord` registra el snapshot de cada
/// visita.
model MedicalRecord {
  id              String   @id @default(cuid())
  appointmentId   String   @unique
  patientId       String
  doctorId        String
  /// Motivo principal de la consulta — texto libre.
  reason          String
  /// Síntomas relatados por el paciente — texto libre, generalmente
  /// listado separado por saltos de línea.
  symptoms        String?
  /// Enfermedades existentes / antecedentes relevantes capturados en
  /// esa cita. Puede sobrescribir / complementar lo que ya está en
  /// Patient.conditions[].
  existingConditions String?
  /// Diagnóstico provisional / impresión clínica del médico.
  diagnosis       String?
  /// Tratamiento o indicaciones — receta, controles, derivaciones.
  treatment       String?
  /// Notas adicionales privadas del médico.
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
}

// ─── Chat Messages (CHAT-modality appointments) ───────────────────────────────
//
// One Appointment ↔ many ChatMessage. Both participants (patient + doctor)
// can read/write messages while the appointment is in PENDING/UPCOMING/
// ONGOING status. Once the appointment moves to COMPLETED/CANCELLED/
// NO_SHOW the chat goes read-only — that's enforced by the service layer,
// not the schema, so we can still surface chat history in the medical
// record after a consult.
//
// `senderId` references the User.id of the participant (doctor's user or
// patient's user). We don't store role here — it's derivable from the
// appointment + senderId in the service if needed.
//
// `readAt` is set the first time the recipient opens the conversation
// after `createdAt`. UI uses it to render Insta/FB-style "Visto" hints.

// ─── Plans / Subscriptions ────────────────────────────────────────────────────
//
// Two-axis pricing: every plan is targeted at a specific audience (DOCTOR or
// CLINIC) and a tier (FREE / PRO / PREMIUM). The superadmin can edit prices,
// limits and feature flags from the panel — we don't hardcode any business
// rules here so no code change is needed when commercial conditions change.
//
// `modules` is a free-form string array (e.g. ['ONLINE', 'PRESENCIAL', 'CHAT',
// 'REPORTS', 'MULTI_DOCTOR']) consulted by feature gates throughout the app.
// `limits` is a JSON bag (`{ maxAppointmentsPerMonth: 5, maxDoctors: 1 }`) —
// kept as JSON so the superadmin can add new dimensions without migrating.

model Plan {
  id               String        @id @default(cuid())
  code             PlanCode      // FREE / PRO / PREMIUM
  audience         PlanAudience  // DOCTOR / CLINIC
  name             String
  description      String?
  monthlyPrice     Float         @default(0)
  modules          String[]      @default([])
  limits           Json?
  isActive         Boolean       @default(true)
  /// Display order in pricing UI. Lower = first.
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  subscriptions Subscription[]

  @@unique([audience, code])
  @@index([isActive])
}

model Subscription {
  id            String              @id @default(cuid())
  userId        String              // The DOCTOR or CLINIC user that owns it
  planId        String
  status        SubscriptionStatus  @default(ACTIVE)
  /// When the current paid period started.
  startsAt      DateTime            @default(now())
  /// When the current paid period ends. After this we degrade to FREE
  /// unless renewed.
  expiresAt     DateTime
  /// Last PayPhone payment that funded this subscription. Null on FREE.
  lastPaymentId String?
  /// Whether the user has expressed intent to auto-renew. We don't
  /// auto-charge yet (PayPhone tokenisation is a later piece) but we
  /// surface this in the UI as a reminder/email trigger.
  autoRenew     Boolean             @default(true)
  cancelledAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([expiresAt])
}

// ─── App Settings (runtime-editable config) ───────────────────────────────────
//
// Single-row table keyed by `key`. The superadmin edits SMTP credentials,
// PayPhone tokens, branding, etc. from the panel and the back-end services
// read through a 30-second cache. Env vars stay as the bootstrap default —
// when DB has no value for a key, code falls back to `process.env`.

model AppSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  /// Plain-text label used in the admin UI to group keys.
  category  String   @default("GENERAL")
  /// When true, the value is rendered as a password input in the admin UI.
  isSecret  Boolean  @default(false)
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([category])
}

model ChatMessage {
  id            String   @id @default(cuid())
  appointmentId String
  senderId      String   // User.id of the author (patient or doctor)
  content       String
  // Optional attachment metadata. Free-form to keep MVP simple — stores
  // a public URL to an uploaded file (image, doc, etc.). Once we have a
  // proper object-storage flow we'll graduate to a typed sub-model.
  attachmentUrl  String?
  attachmentName String?
  attachmentMime String?
  // Soft-delete support — sender can "unsend" within a short window.
  deletedAt     DateTime?
  // Set when the OTHER party first GETs the conversation after this
  // message was created.
  readAt        DateTime?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([senderId])
  @@index([appointmentId, createdAt])
}
