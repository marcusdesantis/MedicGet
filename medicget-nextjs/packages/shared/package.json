{
  "name": "@medicget/shared",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/prisma.ts",
    "./response": "./src/response.ts",
    "./auth": "./src/auth.ts",
    "./errors": "./src/errors.ts",
    "./env": "./src/env.ts",
    "./paginate": "./src/paginate.ts",
    "./validate": "./src/validate.ts",
    "./email": "./src/email.ts",
    "./meeting": "./src/meeting.ts",
    "./payphone": "./src/payphone.ts",
    "./settings": "./src/settings.ts",
    "./subscription": "./src/subscription.ts",
    "./webpush": "./src/webpush.ts",
    "./notifications": "./src/notifications.ts"
  },
  "scripts": {
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "prisma:seed": "ts-node --esm prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "seed": "ts-node --esm prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
