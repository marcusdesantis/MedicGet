# =============================================================================
# Config de Jitsi self-hosted para MedicGet. Copiá a `.env` y completá lo
# marcado con CAMBIAR. Los secrets de componentes (JICOFO_*, JVB_*, etc.)
# los genera `gen-passwords.sh` — NO los pongas a mano.
# =============================================================================

# Dónde Jitsi guarda su configuración persistente en el host.
CONFIG=~/.jitsi-meet-cfg

# Zona horaria.
TZ=America/Guayaquil

# ─── URL pública ────────────────────────────────────────────────────────────
# El dominio por el que entran médicos y pacientes. Debe tener un registro
# DNS A apuntando a la IP del VPS y un cert TLS (lo maneja el nginx HOST).
PUBLIC_URL=https://meet.medicget.io

# ─── Media (JVB) ─────────────────────────────────────────────────────────────
# IP PÚBLICA del VPS. CRÍTICO: sin esto el audio/video no fluye porque el
# JVB no sabe qué IP anunciar a los navegadores. Poné la IP real del server.
DOCKER_HOST_ADDRESS=89.117.58.101    # CAMBIAR si tu IP es otra
JVB_ADVERTISE_IPS=89.117.58.101      # CAMBIAR (misma IP pública)

# ─── Sin autenticación ───────────────────────────────────────────────────────
# El punto de todo esto: cualquiera con el link inicia/entra sin loguearse.
ENABLE_AUTH=0
ENABLE_GUESTS=1
AUTH_TYPE=internal

# ─── Dominios XMPP internos (no tocar — son internos al stack) ────────────────
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_SERVER=xmpp.meet.jitsi
XMPP_BOSH_URL_BASE=http://xmpp.meet.jitsi:5280
JICOFO_AUTH_USER=focus
JVB_AUTH_USER=jvb
JVB_BREWERY_MUC=jvbbrewery
JVB_PREFER_SCTP=0

# ─── Secrets de componentes — los llena gen-passwords.sh ──────────────────────
JICOFO_COMPONENT_SECRET=
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
JIGASI_XMPP_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=

# ─── Defaults requeridos por las imágenes (dejar vacíos) ──────────────────────
GLOBAL_MODULES=
GLOBAL_CONFIG=
LDAP_URL=
XMPP_MODULES=
XMPP_MUC_MODULES=
XMPP_INTERNAL_MUC_MODULES=
JIGASI_XMPP_USER=
JIBRI_RECORDER_USER=
JIBRI_XMPP_USER=
