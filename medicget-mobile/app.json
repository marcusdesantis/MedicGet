{
  "expo": {
    "name": "MedicGet",
    "slug": "medicget",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "medicget",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medicget.app",
      "buildNumber": "2"
    },
    "android": {
      "package": "com.medicget.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MedicGet necesita acceso a tus fotos para subir el documento de tu licencia.",
          "cameraPermission": "MedicGet necesita acceso a la cámara para tomar una foto de tu licencia."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://medicget.io/api/v1"
    }
  }
}
